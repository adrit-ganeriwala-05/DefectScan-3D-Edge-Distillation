# =============================================================================
#  DefectScan AI — UPDATED .gitignore
# =============================================================================

# ── Virtual environment ───────────────────────────────────────────────────────
.venv/
venv/
env/
__pycache__/
*.pyc
*.pyo
*.pyd

# ── Dataset (too large for git — see README for download instructions) ────────
dataset/
dataset_raw/

# ── Model weights ───────────────────────────────────────────────────────────
# Ignore all .pth files by default to prevent accidental large uploads
*.pth

# EXCEPTIONS: Allow the optimized student models for deployment (under 100MB)
!outputs/models/student_int8.pth
!outputs/models/student_fp32_best.pth

# ── Output artefacts ──────────────────────────────────────────────────────────
# We ignore the models folder specifically but allow the figures for the README
outputs/models/*
# Re-allow the specific files we want within that ignored folder
!outputs/models/student_int8.pth
!outputs/models/student_fp32_best.pth

# ── IDE and OS files ──────────────────────────────────────────────────────────
.vscode/
.idea/
.DS_Store
Thumbs.db
*.swp
*.swo

# ── Jupyter ───────────────────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb

# ── Logs and temp ────────────────────────────────────────────────────────────
*.log
*.tmp
*.bak
wandb/

# ── Build artefacts ───────────────────────────────────────────────────────────
dist/
build/
*.egg-info/